# ──────────────────────────────────────────────────────────────
# trainer-log 환경변수 예시
# 사용법: 이 파일을 `.env` 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# Vite 의 정책상 모든 변수는 VITE_ 접두사 필수.
# .env 는 .gitignore 에 포함되어 있어야 함 (절대 커밋 금지).
# ──────────────────────────────────────────────────────────────

# ── 필수 ─ Supabase ───────────────────────────────────────────
# Supabase 프로젝트 → Settings → API 에서 복사
#   - Project URL  → VITE_SUPABASE_URL
#   - anon public  → VITE_SUPABASE_ANON_KEY
# 이 두 개가 없으면 앱이 실행되지 않습니다 (supabase.js:7 throw).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# ── 선택 ─ Web Push (Trainer 앱 알림) ─────────────────────────
# 수업 시간 푸시 알림 기능에만 필요. 없으면 알림만 비활성화되고
# 나머지 기능은 정상 동작.
# 발급: https://web-push-codelab.glitch.me/  또는 `npx web-push generate-vapid-keys`
# Public key 만 client 에. Private key 는 서버(Supabase Edge Function) 에서만 사용.
VITE_VAPID_PUBLIC_KEY=

# ── 선택 ─ Admin 포털 ID/PW (admin.html 진입점) ───────────────
# admin.html 에서 사용. 미설정 시 폴백 랜덤 문자열로 만들어져
# 로그인 자체가 절대 통과되지 않음 (=admin 비활성화 효과).
VITE_ADMIN_ID=
VITE_ADMIN_PASSWORD=

# ── 선택 ─ Admin RPC 토큰 ─────────────────────────────────────
# app_settings 테이블 변경 RPC 보호용. 미설정 시 일부 admin 기능
# (예: app_settings 삭제) 이 동작하지 않음.
# DB 함수의 하드코딩 토큰과 일치해야 함.
VITE_ADMIN_DB_TOKEN=
