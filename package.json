{
  "name": "trainer-log",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:portal":   "npm --workspace @trainer-log/portal run dev",
    "dev:crm":      "npm --workspace @trainer-log/crm run dev",
    "dev:admin":    "npm --workspace @trainer-log/admin run dev",
    "build":        "npm run build --workspaces --if-present",
    "build:portal": "npm --workspace @trainer-log/portal run build",
    "build:crm":    "npm --workspace @trainer-log/crm run build",
    "build:admin":  "npm --workspace @trainer-log/admin run build"
  }
}
